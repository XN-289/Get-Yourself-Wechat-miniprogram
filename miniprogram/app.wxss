/* ========== CSS Variables ========== */
page {
  --color-primary: #4F46E5;
  --color-primary-light: #818CF8;
  --color-primary-bg: #EEF2FF;
  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-text: #1F2937;
  --color-text-secondary: #6B7280;
  --color-text-light: #9CA3AF;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-border: #E5E7EB;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  line-height: 1.6;
}

.container { padding: var(--space-lg); }

.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}
.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}
.btn-outline::after { border: none; }

.btn-ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border: none;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  margin-right: var(--space-xs);
}

.form-group { margin-bottom: var(--space-lg); }
.form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xs);
  display: block;
}
.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
  min-height: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
.loading-text { color: var(--color-text-light); font-size: 28rpx; }

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; }
.empty-hint { font-size: 26rpx; color: var(--color-text-light); }
