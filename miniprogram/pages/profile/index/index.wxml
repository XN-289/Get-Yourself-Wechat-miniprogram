<view class="page-profile">
  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="login-hero"><text class="login-icon">👤</text><text class="login-title">欢迎使用 Get Yourself</text><text class="login-desc">记录每一次成长，发现更好的自己</text></view>
    <button class="btn-primary" style="width:80%" bindtap="onLogin">微信一键登录</button>
  </view>
  <view wx:else>
    <view class="profile-card">
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
        <view wx:else class="avatar-default"><text>👤</text></view>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{userInfo.nickname || '未设置昵称'}}</text>
        <text class="profile-detail" wx:if="{{userInfo.school}}">{{userInfo.school}}</text>
      </view>
      <text class="edit-icon" bindtap="onEditProfile">✎</text>
    </view>
    <view class="stats-card" wx:if="{{summary}}">
      <view class="stats-row">
        <view class="stat-item"><text class="stat-num">{{summary.completedCount || 0}}</text><text class="stat-label">完成记录</text></view>
        <view class="stat-divider"></view>
        <view class="stat-item"><text class="stat-num">{{summary.categoryCount || 0}}</text><text class="stat-label">覆盖类别</text></view>
      </view>
    </view>
    <view class="menu-card">
      <view class="menu-item" bindtap="onEditProfile"><text class="menu-icon">✏️</text><text class="menu-text">编辑资料</text><text class="menu-arrow">›</text></view>
    </view>
    <view class="logout-section"><button class="btn-ghost" style="color:var(--color-danger);width:100%" bindtap="onLogout">退出登录</button></view>
  </view>
</view>
