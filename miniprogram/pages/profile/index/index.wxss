.page-profile { min-height: 100vh; }
.login-prompt { display: flex; flex-direction: column; align-items: center; padding: 120rpx 60rpx; }
.login-hero { display: flex; flex-direction: column; align-items: center; margin-bottom: 60rpx; }
.login-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.login-title { font-size: 36rpx; font-weight: 600; margin-bottom: 12rpx; }
.login-desc { font-size: 28rpx; color: var(--color-text-secondary); }
.profile-card { background: var(--color-primary); padding: 40rpx 30rpx; display: flex; align-items: center; }
.avatar-wrap { margin-right: 24rpx; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.3); }
.avatar-default { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.profile-info { flex: 1; }
.profile-name { display: block; font-size: 34rpx; font-weight: 600; color: #fff; margin-bottom: 6rpx; }
.profile-detail { display: block; font-size: 26rpx; color: rgba(255,255,255,0.7); }
.edit-icon { font-size: 36rpx; color: rgba(255,255,255,0.6); padding: 16rpx; }
.stats-card { margin: -20rpx 30rpx 0; background: var(--color-card); border-radius: var(--radius-lg); padding: 28rpx; position: relative; z-index: 1; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); }
.stats-row { display: flex; align-items: center; }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: var(--color-primary); }
.stat-label { font-size: 24rpx; color: var(--color-text-secondary); }
.stat-divider { width: 1rpx; height: 60rpx; background: var(--color-border); }
.menu-card { margin: 24rpx 30rpx 0; background: var(--color-card); border-radius: var(--radius-lg); overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 28rpx; border-bottom: 1rpx solid var(--color-border); }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 32rpx; margin-right: 20rpx; width: 44rpx; text-align: center; }
.menu-text { flex: 1; font-size: 28rpx; }
.menu-arrow { font-size: 28rpx; color: var(--color-text-light); }
.logout-section { padding: 60rpx 30rpx; }
