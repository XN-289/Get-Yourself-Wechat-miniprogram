.page-ai { min-height: 100vh; }
.input-section { background: var(--color-card); padding: 30rpx; border-bottom: 1rpx solid var(--color-border); }
.ai-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 24rpx; }
.ai-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.ai-title { font-size: 32rpx; font-weight: 600; }
.ai-desc { font-size: 26rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.input-wrap { background: var(--color-bg); border-radius: var(--radius-lg); padding: 20rpx; margin-bottom: 16rpx; }
.input-textarea { width: 100%; font-size: 28rpx; min-height: 80rpx; line-height: 1.6; }
.quick-needs { margin-bottom: 16rpx; }
.quick-label { font-size: 24rpx; color: var(--color-text-light); display: block; margin-bottom: 12rpx; }
.quick-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.quick-tag { font-size: 24rpx; padding: 10rpx 20rpx; background: var(--color-primary-bg); color: var(--color-primary); border-radius: var(--radius-full); }
.result-message { padding: 20rpx 30rpx; background: var(--color-primary-bg); color: var(--color-primary); font-size: 26rpx; }
.error-message { padding: 20rpx 30rpx; background: #FEF2F2; color: var(--color-danger); font-size: 26rpx; }
.result-section { padding: 20rpx 30rpx; }
.result-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.result-title { font-size: 30rpx; font-weight: 600; flex: 1; }
.result-count { font-size: 24rpx; color: var(--color-text-light); margin-right: 20rpx; }
.result-clear { font-size: 24rpx; color: var(--color-primary); }
.recommend-card { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.recommend-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.recommend-score { width: 80rpx; height: 80rpx; border-radius: 50%; background: var(--color-primary); display: flex; flex-direction: column; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.score-num { font-size: 28rpx; font-weight: 700; color: #fff; line-height: 1; }
.score-label { font-size: 16rpx; color: rgba(255,255,255,0.7); margin-top: 2rpx; }
.recommend-info { flex: 1; }
.recommend-title { display: block; font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.recommend-org { display: block; font-size: 26rpx; color: var(--color-text-secondary); }
.recommend-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.recommend-reason { font-size: 26rpx; color: var(--color-text-secondary); line-height: 1.6; display: block; margin-bottom: 12rpx; }
.recommend-evidence { background: var(--color-bg); border-radius: var(--radius-md); padding: 16rpx; }
.ev-label { font-size: 24rpx; color: var(--color-text-light); display: block; margin-bottom: 8rpx; }
.ev-item { font-size: 24rpx; color: var(--color-text-secondary); display: block; line-height: 1.6; }
