<view class="page-ai">
  <view class="input-section">
    <view class="ai-header"><text class="ai-icon">✨</text><text class="ai-title">AI 智能推荐</text><text class="ai-desc">告诉我你想做什么，帮你找到合适的活动</text></view>
    <view class="input-wrap"><textarea class="input-textarea" placeholder="例如：想找线上实习机会、想提升日语能力..." value="{{need}}" bindinput="onNeedInput" maxlength="200" auto-height/></view>
    <view class="quick-needs" wx:if="{{recommendations.length === 0 && !loading}}">
      <text class="quick-label">试试这些：</text>
      <view class="quick-tags"><text wx:for="{{quickNeeds}}" wx:key="*this" class="quick-tag" bindtap="onQuickNeed" data-need="{{item}}">{{item}}</text></view>
    </view>
    <button class="btn-primary" style="width:100%" bindtap="onSubmit" loading="{{loading}}" disabled="{{loading || !need.trim()}}">{{loading ? '分析中...' : '获取推荐'}}</button>
  </view>
  <view wx:if="{{message}}" class="result-message"><text>{{message}}</text></view>
  <view wx:if="{{error}}" class="error-message"><text>{{error}}</text></view>
  <view wx:if="{{recommendations.length > 0}}" class="result-section">
    <view class="result-header"><text class="result-title">推荐结果</text><text class="result-count">{{recommendations.length}} 个</text><text class="result-clear" bindtap="onClear">清空</text></view>
    <view wx:for="{{recommendations}}" wx:key="event.id" class="recommend-card" bindtap="onEventTap" data-id="{{item.event.id}}">
      <view class="recommend-header">
        <view class="recommend-score"><text class="score-num">{{item.score}}</text><text class="score-label">匹配度</text></view>
        <view class="recommend-info"><text class="recommend-title">{{item.event.title}}</text><text class="recommend-org">{{item.event.organizationName}}</text></view>
      </view>
      <view class="recommend-tags">
        <text class="tag" style="background:{{item.event.categoryColor}}20;color:{{item.event.categoryColor}}">{{item.event.categoryLabel}}</text>
        <text class="tag">{{item.event.location}}</text>
      </view>
      <text class="recommend-reason">{{item.reason}}</text>
      <view wx:if="{{item.evidence && item.evidence.length > 0}}" class="recommend-evidence">
        <text class="ev-label">匹配依据：</text>
        <text wx:for="{{item.evidence}}" wx:for-item="ev" wx:key="*this" class="ev-item">• {{ev}}</text>
      </view>
    </view>
  </view>
  <view wx:if="{{!loading && message && recommendations.length === 0 && !error}}" class="empty-wrap">
    <text class="empty-icon">🔍</text><text class="empty-text">没有找到足够匹配的活动</text>
  </view>
</view>
