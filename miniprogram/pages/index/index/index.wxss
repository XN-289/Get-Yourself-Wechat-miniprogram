.search-bar { padding: 20rpx 30rpx; background: var(--color-primary); }
.search-input-wrap { display: flex; align-items: center; background: #fff; border-radius: var(--radius-full); padding: 16rpx 24rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.ai-banner { margin: 20rpx 30rpx; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: var(--radius-lg); padding: 28rpx 30rpx; display: flex; align-items: center; justify-content: space-between; }
.ai-banner-content { display: flex; align-items: center; }
.ai-banner-icon { font-size: 40rpx; margin-right: 20rpx; }
.ai-banner-text { display: flex; flex-direction: column; }
.ai-banner-title { color: #fff; font-size: 30rpx; font-weight: 600; }
.ai-banner-desc { color: rgba(255,255,255,0.8); font-size: 24rpx; margin-top: 4rpx; }
.ai-banner-arrow { color: rgba(255,255,255,0.6); font-size: 36rpx; }
.category-scroll { white-space: nowrap; padding: 20rpx 30rpx; }
.category-list { display: inline-flex; gap: 16rpx; }
.category-item { display: inline-block; padding: 12rpx 28rpx; border-radius: var(--radius-full); font-size: 26rpx; color: var(--color-text-secondary); background: var(--color-card); white-space: nowrap; }
.category-item.active { background: var(--color-primary); color: #fff; }
.event-list { padding: 0 30rpx; }
.event-card { background: var(--color-card); border-radius: var(--radius-lg); padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.event-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.event-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: var(--radius-full); font-weight: 500; }
.event-time { font-size: 24rpx; color: var(--color-text-light); }
.event-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.event-org { font-size: 26rpx; color: var(--color-text-secondary); display: block; margin-bottom: 16rpx; }
.event-meta { display: flex; justify-content: space-between; align-items: center; }
.event-location { font-size: 24rpx; color: var(--color-text-light); }
.event-benefit { font-size: 24rpx; color: var(--color-warning); font-weight: 500; }
