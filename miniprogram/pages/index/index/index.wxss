/* 首页样式 */
.page-index {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: var(--color-primary);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: var(--radius-full);
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 0 8rpx;
}

/* AI 推荐横幅 */
.ai-banner {
  margin: 20rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-lg);
  padding: 28rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.ai-banner-content {
  display: flex;
  align-items: center;
}

.ai-banner-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.ai-banner-text {
  display: flex;
  flex-direction: column;
}

.ai-banner-title {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

.ai-banner-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 4rpx;
}

.ai-banner-arrow {
  color: rgba(255, 255, 255, 0.6);
  font-size: 36rpx;
}

/* 分类筛选 */
.category-scroll {
  white-space: nowrap;
  padding: 20rpx 30rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  white-space: nowrap;
  transition: all 0.2s;
}

.category-item.active {
  background: var(--color-primary);
  color: #FFFFFF;
}

/* 事件列表 */
.event-list {
  padding: 20rpx 30rpx;
}

.event-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.event-card:active {
  transform: scale(0.98);
}

.event-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.event-tag-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.event-tag-icon {
  font-size: 24rpx;
}

.event-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

.event-time {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.event-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.event-org {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.event-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.event-location {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.event-benefit {
  font-size: 24rpx;
  color: var(--color-warning);
  font-weight: 500;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: var(--color-text-light);
  font-size: 28rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 错误状态 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 30rpx;
  text-align: center;
}
