.page-detail { padding-bottom: 140rpx; }
.hero { background: var(--color-primary); padding: 40rpx 30rpx 50rpx; }
.status-badge { display: inline-block; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: var(--radius-full); margin-bottom: 16rpx; }
.status-badge.ACTIVE { background: rgba(255,255,255,0.2); color: #fff; }
.status-badge.COMPLETED { background: rgba(16,185,129,0.3); color: #fff; }
.hero-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.hero-cat { font-size: 26rpx; color: rgba(255,255,255,0.7); }
.info-card { margin: 20rpx 30rpx 0; background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; }
.label { display: block; font-size: 24rpx; color: var(--color-text-light); margin-bottom: 8rpx; }
.value { display: block; font-size: 28rpx; line-height: 1.6; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--color-card); padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06); }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.modal-content { width: 100%; background: var(--color-card); border-radius: 32rpx 32rpx 0 0; padding: 40rpx 30rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.modal-title { display: block; font-size: 34rpx; font-weight: 600; margin-bottom: 24rpx; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 30rpx; }
.modal-actions .btn-ghost { flex: 1; } .modal-actions .btn-primary { flex: 2; }
