.page-achievement { min-height: 100vh; }
.stats-header { background: var(--color-primary); padding: 30rpx 30rpx 40rpx; }
.stats-grid { display: flex; justify-content: center; gap: 60rpx; margin-bottom: 24rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 48rpx; font-weight: 700; color: #fff; }
.stat-label { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.ability-section { background: rgba(255,255,255,0.1); border-radius: var(--radius-lg); padding: 24rpx; }
.ability-title { display: block; font-size: 24rpx; color: rgba(255,255,255,0.6); margin-bottom: 16rpx; }
.ability-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.ability-name { font-size: 24rpx; color: rgba(255,255,255,0.8); width: 140rpx; }
.ability-track { flex: 1; height: 12rpx; background: rgba(255,255,255,0.15); border-radius: 6rpx; margin: 0 16rpx; overflow: hidden; }
.ability-fill { height: 100%; background: linear-gradient(90deg, #818CF8, #C084FC); border-radius: 6rpx; }
.ability-score { font-size: 24rpx; color: rgba(255,255,255,0.8); width: 50rpx; text-align: right; }
.section-header { padding: 24rpx 30rpx 12rpx; }
.section-title { font-size: 30rpx; font-weight: 600; }
.record-list { padding: 0 30rpx 20rpx; }
.record-card { background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.record-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.record-time { font-size: 24rpx; color: var(--color-text-light); }
.record-title { display: block; font-size: 30rpx; font-weight: 600; margin-bottom: 6rpx; }
.record-org { display: block; font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.record-preview { background: var(--color-bg); border-radius: var(--radius-md); padding: 16rpx; }
.preview-text { font-size: 26rpx; color: var(--color-text-secondary); display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
