.page-detail { padding-bottom: 40rpx; }
.hero { background: var(--color-primary); padding: 40rpx 30rpx 50rpx; }
.hero-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; margin: 16rpx 0 8rpx; }
.hero-org { display: block; font-size: 28rpx; color: rgba(255,255,255,0.8); margin-bottom: 8rpx; }
.hero-time { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.info-card { margin: 20rpx 30rpx 0; background: var(--color-card); border-radius: var(--radius-lg); padding: 24rpx; }
.label { display: block; font-size: 24rpx; color: var(--color-text-light); margin-bottom: 8rpx; }
.value { display: block; font-size: 28rpx; line-height: 1.6; }
.reflection-section { margin: 30rpx; background: var(--color-card); border-radius: var(--radius-lg); padding: 28rpx; }
.reflection-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 600; }
.edit-btn { font-size: 26rpx; color: var(--color-primary); padding: 8rpx 16rpx; }
.ref-block { margin-bottom: 24rpx; }
.ref-label { display: block; font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; font-weight: 500; }
.ref-text { display: block; font-size: 28rpx; line-height: 1.8; }
.ref-text.empty { color: var(--color-text-light); font-style: italic; }
.edit-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.edit-actions .btn-ghost { flex: 1; } .edit-actions .btn-primary { flex: 2; }
