.page-detail { padding-bottom: 140rpx; }
.hero { background: var(--color-primary); padding: 40rpx 30rpx 50rpx; }
.hero-title { display: block; font-size: 38rpx; font-weight: 700; color: #fff; margin: 16rpx 0 12rpx; }
.hero-org { font-size: 28rpx; color: rgba(255,255,255,0.8); }
.info-card { margin: -30rpx 30rpx 0; background: var(--color-card); border-radius: var(--radius-lg); padding: 28rpx; position: relative; z-index: 1; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); }
.info-row { display: flex; align-items: center; padding: 12rpx 0; }
.info-row + .info-row { border-top: 1rpx solid var(--color-border); }
.info-icon { font-size: 28rpx; margin-right: 16rpx; width: 40rpx; text-align: center; }
.info-text { font-size: 28rpx; flex: 1; }
.section { padding: 30rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.detail-text { font-size: 28rpx; color: var(--color-text-secondary); line-height: 1.8; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--color-card); padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06); }
.bottom-btn { width: 100%; }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.modal-content { width: 100%; background: var(--color-card); border-radius: 32rpx 32rpx 0 0; padding: 40rpx 30rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.modal-title { display: block; font-size: 34rpx; font-weight: 600; margin-bottom: 24rpx; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 30rpx; }
.modal-actions .btn-ghost { flex: 1; }
.modal-actions .btn-primary { flex: 2; }
