<!-- pages/challenge/create/create.wxml -->
<view class="page-create">

  <!-- 封面图 -->
  <view class="cover-section" bindtap="onChooseCover">
    <image
      wx:if="{{form.coverImage}}"
      class="cover-preview"
      src="{{form.coverImage}}"
      mode="aspectFill"
    />
    <view wx:else class="cover-placeholder">
      <text class="cover-icon">📷</text>
      <text class="cover-text">点击上传封面图</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-section">

    <!-- 标题 -->
    <view class="form-item">
      <text class="form-label">挑战标题</text>
      <input
        class="form-input"
        placeholder="给你的挑战起个名字"
        value="{{form.title}}"
        bindinput="onTitleInput"
        maxlength="30"
      />
    </view>

    <!-- 描述 -->
    <view class="form-item">
      <text class="form-label">挑战描述</text>
      <textarea
        class="form-textarea"
        placeholder="描述一下这个挑战的内容和规则..."
        value="{{form.description}}"
        bindinput="onDescInput"
        maxlength="500"
        auto-height
      />
    </view>

    <!-- 分类 -->
    <view class="form-item">
      <text class="form-label">挑战分类</text>
      <picker
        mode="selector"
        range="{{categories}}"
        value="{{categoryIndex}}"
        bindchange="onCategoryChange"
      >
        <view class="picker-value">
          {{categoryIndex >= 0 ? categories[categoryIndex] : '请选择分类'}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 天数 -->
    <view class="form-item">
      <text class="form-label">挑战天数</text>
      <picker
        mode="selector"
        range="{{durationOptions}}"
        value="{{durationIndex}}"
        bindchange="onDurationChange"
      >
        <view class="picker-value">
          {{durationOptions[durationIndex]}} 天
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 难度 -->
    <view class="form-item">
      <text class="form-label">难度等级</text>
      <view class="difficulty-row">
        <view
          class="difficulty-star {{form.difficulty >= item ? 'active' : ''}}"
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="*this"
          bindtap="onDifficultyTap"
          data-level="{{item}}"
        >⭐</view>
      </view>
    </view>

  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="btn btn-primary btn-block"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '创建中...' : '发布挑战'}}
    </button>
  </view>

</view>
