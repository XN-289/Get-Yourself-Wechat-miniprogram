/* pages/challenge/create/create.wxss */

.page-create {
  padding-bottom: 200rpx;
}

/* 封面图 */
.cover-section {
  margin: 24rpx;
  height: 360rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-bg);
}
.cover-preview {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}
.cover-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.cover-text {
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
}

/* 表单 */
.form-section {
  padding: 0 24rpx;
}
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.form-label {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  margin-bottom: 16rpx;
}
.form-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
}
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  box-sizing: border-box;
}

/* 选择器 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  color: var(--color-text);
}
.picker-arrow {
  font-size: 36rpx;
  color: var(--color-text-placeholder);
}

/* 难度选择 */
.difficulty-row {
  display: flex;
  gap: 20rpx;
}
.difficulty-star {
  font-size: 48rpx;
  opacity: 0.3;
  transition: opacity 0.2s;
}
.difficulty-star.active {
  opacity: 1;
}

/* 提交 */
.submit-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: var(--color-bg-white);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.06);
}
