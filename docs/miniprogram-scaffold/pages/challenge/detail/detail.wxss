/* pages/challenge/detail/detail.wxss */

.page-challenge-detail {
  padding-bottom: 240rpx;
}

.cover {
  width: 100%;
  height: 400rpx;
}

.info-card {
  margin: -40rpx 24rpx 0;
  position: relative;
  z-index: 1;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  border-top: 1rpx solid var(--color-border);
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--color-primary);
}
.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.info-row .label {
  width: 140rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.desc-text {
  font-size: var(--font-md);
  line-height: 1.8;
  color: var(--color-text);
}

/* 打卡网格 */
.checkin-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.checkin-day {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--color-bg);
}
.checkin-day.checked {
  background: var(--color-success);
  color: #ffffff;
}
.day-num {
  font-size: var(--font-xs);
}
.day-status {
  font-size: var(--font-xs);
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: var(--color-bg-white);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
  color: var(--color-text-placeholder);
}
