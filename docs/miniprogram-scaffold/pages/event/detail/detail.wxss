/* pages/event/detail/detail.wxss */

.page-event-detail {
  padding-bottom: 200rpx;
}

.cover {
  width: 100%;
  height: 400rpx;
}

.info-card {
  margin: -40rpx 24rpx 0;
  position: relative;
  z-index: 1;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: var(--font-md);
}
.info-row .label {
  width: 140rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.desc-content {
  font-size: var(--font-md);
  line-height: 1.8;
  color: var(--color-text);
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: var(--color-bg-white);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
  color: var(--color-text-placeholder);
}
