<!-- pages/event/search/search.wxml -->
<view class="page-search">

  <!-- 搜索输入框 -->
  <view class="search-header">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索活动名称、分类..."
        value="{{keyword}}"
        bindinput="onInput"
        focus
        confirm-type="search"
        bindconfirm="doSearch"
      />
      <text
        wx:if="{{keyword}}"
        class="clear-btn"
        bindtap="onClear"
      >✕</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="result-list" wx:if="{{searched}}">
    <view
      class="result-item card"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="onResultTap"
      data-id="{{item.id}}"
    >
      <image class="result-cover" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="result-info">
        <text class="text-bold text-ellipsis">{{item.title}}</text>
        <text class="text-sm text-secondary mt-xs">📅 {{item.dateText}}</text>
        <view class="flex items-center mt-xs">
          <text class="tag">{{item.categoryName}}</text>
          <text class="text-xs text-secondary ml-sm">{{item.participantCount}}人参加</text>
        </view>
      </view>
    </view>

    <!-- 空结果 -->
    <view wx:if="{{!results.length && !loading}}" class="empty-state">
      <text class="empty-text">没有找到相关活动</text>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-more">
      <text>搜索中...</text>
    </view>
    <view wx:if="{{!hasMore && results.length}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 未搜索时的提示 -->
  <view wx:if="{{!searched}}" class="hint-state">
    <text class="hint-icon">🔎</text>
    <text class="hint-text">输入关键词搜索活动</text>
  </view>

</view>
