<!-- pages/achievement/list/list.wxml -->
<view class="page-achievement-list">

  <!-- 成就统计 -->
  <view class="stats-banner">
    <view class="stats-item">
      <text class="stats-num">{{stats.unlocked}}</text>
      <text class="stats-label">已解锁</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{stats.total}}</text>
      <text class="stats-label">总成就</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{stats.points}}</text>
      <text class="stats-label">积分</text>
    </view>
  </view>

  <!-- 成就列表 -->
  <view class="list-wrap">
    <view
      class="achievement-item card {{item.unlocked ? '' : 'locked'}}"
      wx:for="{{achievements}}"
      wx:key="id"
      bindtap="onItemTap"
      data-id="{{item.id}}"
    >
      <view class="ach-icon-wrap">
        <image
          class="ach-icon"
          src="{{item.icon}}"
          mode="aspectFit"
        />
        <view wx:if="{{!item.unlocked}}" class="lock-overlay">🔒</view>
      </view>
      <view class="ach-info">
        <text class="text-bold">{{item.name}}</text>
        <text class="text-sm text-secondary mt-xs text-clamp-2">{{item.description}}</text>
        <view class="progress-bar mt-xs" wx:if="{{!item.unlocked}}">
          <view class="progress-fill" style="width: {{item.progress || 0}}%;" />
        </view>
        <text class="text-xs text-secondary mt-xs" wx:if="{{!item.unlocked}}">
          {{item.progress || 0}}%
        </text>
      </view>
    </view>

    <view wx:if="{{!achievements.length && !loading}}" class="empty-state">
      <text class="empty-text">还没有成就，去完成挑战吧</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

</view>
