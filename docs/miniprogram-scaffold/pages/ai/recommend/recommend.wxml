<!-- pages/ai/recommend/recommend.wxml -->
<view class="page-ai-recommend">

  <!-- AI 介绍 -->
  <view class="ai-banner">
    <text class="ai-emoji">🤖</text>
    <view class="ai-text">
      <text class="text-bold">AI 智能推荐</text>
      <text class="text-sm" style="opacity: 0.85;">根据你的兴趣和行为，为你推荐最合适的活动和挑战</text>
    </view>
  </view>

  <!-- 兴趣标签 -->
  <view class="tags-section" wx:if="{{userTags.length}}">
    <text class="section-label">你的兴趣标签</text>
    <scroll-view scroll-x class="tags-scroll">
      <view
        class="tag-item {{selectedTags.indexOf(item) > -1 ? 'active' : ''}}"
        wx:for="{{userTags}}"
        wx:key="*this"
        bindtap="onTagTap"
        data-tag="{{item}}"
      >
        {{item}}
      </view>
    </scroll-view>
  </view>

  <!-- 推荐列表 -->
  <view class="list-wrap">
    <view class="section-header">
      <text class="text-lg text-bold">为你推荐</text>
      <text
        class="refresh-btn text-sm text-primary"
        bindtap="onRefresh"
      >🔄 换一批</text>
    </view>

    <view
      class="recommend-item card"
      wx:for="{{recommendations}}"
      wx:key="id"
      bindtap="onItemTap"
      data-type="{{item.type}}"
      data-id="{{item.id}}"
    >
      <image class="item-cover" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="item-info">
        <view class="flex items-center">
          <text class="item-type-tag">{{item.type === 'event' ? '活动' : '挑战'}}</text>
          <text class="text-bold text-ellipsis flex-1">{{item.title}}</text>
        </view>
        <text class="text-sm text-secondary mt-xs text-clamp-2">{{item.reason}}</text>
        <view class="flex items-center mt-xs">
          <text class="text-xs text-secondary">{{item.matchScore}}% 匹配</text>
          <view class="match-bar ml-sm">
            <view class="match-fill" style="width: {{item.matchScore}}%;" />
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!recommendations.length && !loading}}" class="empty-state">
      <text class="empty-icon">🎯</text>
      <text class="empty-text">暂无推荐，多参与活动会更精准哦</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <text>AI 正在为你匹配...</text>
  </view>

</view>
