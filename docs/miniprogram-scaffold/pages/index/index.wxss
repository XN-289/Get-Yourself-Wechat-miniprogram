/* pages/index/index.wxss */

.page-index {
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: var(--color-primary);
}
.search-input-placeholder {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
}
.search-icon {
  margin-right: 12rpx;
}

/* Banner */
.banner-swiper {
  height: 320rpx;
  margin: 16rpx 24rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
}

/* AI 入口 */
.ai-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 24rpx;
  padding: 24rpx 32rpx;
}
.ai-entry-left {
  display: flex;
  align-items: center;
}
.ai-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}
.arrow {
  font-size: 40rpx;
  color: var(--color-text-placeholder);
}

/* 分区 */
.section {
  margin-bottom: 32rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
}

/* 活动卡片 */
.event-list {
  padding: 0 24rpx;
}
.event-card {
  display: flex;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.event-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
.event-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

/* 挑战横向滚动 */
.challenge-scroll {
  padding-left: 24rpx;
  white-space: nowrap;
}
.challenge-card {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  margin-right: 20rpx;
  background: var(--color-bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.challenge-cover {
  width: 260rpx;
  height: 180rpx;
}
.challenge-name {
  padding: 16rpx 16rpx 4rpx;
  font-size: var(--font-md);
}
.challenge-scroll .text-xs {
  padding: 0 16rpx 16rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: var(--color-text-placeholder);
  font-size: var(--font-sm);
}
